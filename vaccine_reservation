    async function checkActiveReservation() {
      if (TEST_MODE || !GAS_URL) return false;
      try {
        const payload = { idToken: liff.getIDToken(), appToken: APP_TOKEN, action: 'check_status' };
        const controller = new AbortController();
        const tid = setTimeout(() => controller.abort(), 15000);
        const res = await fetch(GAS_URL, { method: 'POST', body: JSON.stringify(payload), signal: controller.signal });
        clearTimeout(tid);
        const data = JSON.parse(await res.text());
        return !!(data.ok && data.hasActive);
      } catch (e) {
        console.error('[checkActiveReservation]', e);
        return false;
      }
    }

