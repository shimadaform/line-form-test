    // =============================================================
    // メッセージ定数 — 共通の文言はここだけ編集してください
    //   {phone} は CLINIC_INFO の電話番号+telリンクに自動置換されます
    // =============================================================
    const MESSAGES = {
      CONTACT_NOTICE: '内容を確認のうえ、月〜土曜日（祝日を除く）の午後にLINEにて順次ご連絡いたします。',
      URGENT_PHONE_NOTICE: 'お急ぎの場合や内容の変更・キャンセルをご希望の場合は、お電話（{phone}）にてご連絡ください。',
      PHONE_MULTI: '複数のワクチンを接種される場合は、接種間隔などの確認が必要なため、お手数ですがお電話にてご予約ください。',
      PHONE_TICKET: '市区町村が発行した接種券・予診票をお持ちの方は、お手数ですがお電話にてご予約ください。',
    };

    const TEST_MODE = new URLSearchParams(window.location.search).get('test') === '1';

    function formatDate(d) {
      const y = d.getFullYear();
      const m = String(d.getMonth() + 1).padStart(2, '0');
      const day = String(d.getDate()).padStart(2, '0');
      return `${y}-${m}-${day}`;
    }

    function toJpDate(iso) {
      const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(iso || '');
      if (!m) return iso;
      return `${m[1]}年${Number(m[2])}月${Number(m[3])}日`;
    }

    function toSlashDate(iso) {
      const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(iso || '');
      if (!m) return iso;
      return `${m[1]}/${m[2]}/${m[3]}`;
    }

    function calcDateBoundaries() {
      const today = new Date();
      const yesterday = new Date(today);
      yesterday.setDate(today.getDate() - 1);
      const threeDaysLater = new Date(today);
      threeDaysLater.setDate(today.getDate() + 3);
      const oneYearLater = new Date(today);
      oneYearLater.setFullYear(today.getFullYear() + 1);
      return {
        TODAY: formatDate(today),
        YESTERDAY: formatDate(yesterday),
        PREFERRED_MIN: formatDate(threeDaysLater),
        PREFERRED_MAX: formatDate(oneYearLater),
        BIRTHDAY_MIN: '1899-01-01',
      };
    }

    function applyDateBoundariesToDOM(b) {
      ['preferredDate1', 'preferredDate2', 'preferredDate3'].forEach(name => {
        const el = document.querySelector(`input[name="${name}"]`);
        if (el) {
          el.setAttribute('min', b.PREFERRED_MIN);
          el.setAttribute('max', b.PREFERRED_MAX);
        }
      });
      // 過去の接種日（前回接種日・接種歴・別ワクチン）は今日以前
      ['doseDate', 'histDate', 'liveInjDate'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.setAttribute('max', b.TODAY);
      });
      const notice = document.getElementById('preferredDateNotice');
      if (notice) {
        notice.textContent = `${toJpDate(b.PREFERRED_MIN)}以降の日付を選択してください`;
      }
    }

    const KANA_REGEX = /^[ァ-ヶー・　 ]+$/;

    let currentType = null;       // 'single' のときフォームへ
    let currentVaxName = null;    // 選択中のワクチン名
    let selectedRow = null;       // 選択中の内容（行 / {consult:true} / {ticket:true} / null）
    let ROWS = [];                // 有効なワクチン行
    let submissionState = { id: null, inFlight: false, completed: false };
    let formDirty = false;

    function $(id) { return document.getElementById(id); }

    function generateSubmissionId() {
      if (typeof crypto !== 'undefined' && typeof crypto.randomUUID === 'function') {
        return crypto.randomUUID();
      }
      return Date.now().toString(36) + '-' + Math.random().toString(36).slice(2, 10);
    }

    function esc(s) {
      return String(s).replace(/[&<>"']/g, function (c) {
        return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c];
      });
    }

    // ▼ ワクチンマスタ（JSONP）読み込み --------------------------------
    function normalize(list) {
      return list.map(function (r) {
        var b = function (v) { var s = String(v == null ? "" : v).trim().toUpperCase(); return s === "TRUE" || s === "1"; };
        return {
          yuko: ("yuko" in r) ? !!r.yuko : b(r["有効"]),
          order: Number(r.order != null ? r.order : r["表示順"]) || 999,
          id: String(r.id != null ? r.id : r["メニューID"] || ""),
          name: String(r.name != null ? r.name : r["ワクチン名"] || ""),
          kubun: String(r.kubun != null ? r.kubun : r["接種区分"] || ""),
          product: String(r.product != null ? r.product : r["使用ワクチン名"] || ""),
          target: String(r.target != null ? r.target : r["対象者"] || ""),
          price: String(r.price != null ? r.price : r["料金表示"] || ""),
          doses: (function (v) { return (v === "" || v == null) ? null : Number(v); })(r.doses != null ? r.doses : r["使用回数"]),
          history: String(r.history != null ? r.history : r["接種歴確認"] || "").trim(),
          liveInj: ("liveInj" in r) ? !!r.liveInj : b(r["注射生ワクチン"]),
          note: String(r.note != null ? r.note : r["注意書き"] || "")
        };
      });
    }

    function loadJsonp(url, timeoutMs) {
      return new Promise(function (resolve, reject) {
        var cbName = "__vcb_" + Date.now() + "_" + Math.floor(Math.random() * 1e6);
        var script = document.createElement("script");
        var timer = setTimeout(function () { cleanup(); reject(new Error("応答がありません（タイムアウト）。")); }, timeoutMs || 15000);
        function cleanup() {
          clearTimeout(timer);
          try { delete window[cbName]; } catch (_) { window[cbName] = undefined; }
          if (script.parentNode) script.parentNode.removeChild(script);
        }
        window[cbName] = function (data) { cleanup(); resolve(data); };
        script.onerror = function () { cleanup(); reject(new Error("読み込みに失敗しました。")); };
        var sep = url.indexOf("?") >= 0 ? "&" : "?";
        script.src = url + sep + "callback=" + cbName + "&t=" + Date.now();
        document.body.appendChild(script);
      });
    }

    async function loadVaccineMaster() {
      const loadingEl = $('vaxLoading');
      const errEl = $('vaxLoadError');
      if (!VACCINE_MASTER_URL) {
        if (loadingEl) loadingEl.style.display = 'none';
        showInlineError(null, 'vaxLoadError', 'ワクチン一覧の接続先（VACCINE_MASTER_URL）が設定されていません。');
        return;
      }
      try {
        const data = await loadJsonp(VACCINE_MASTER_URL, 15000);
        if (data && data.ok === false) throw new Error(data.error || 'GASエラー');
        const list = (data && data.vaccines) || data;
        if (!Array.isArray(list)) throw new Error('応答形式が不正です。');
        ROWS = normalize(list).filter(function (r) { return r.yuko; });
        ROWS.sort(function (a, b) { return a.order - b.order; });
        if (loadingEl) loadingEl.style.display = 'none';
        if (ROWS.length === 0) {
          showInlineError(null, 'vaxLoadError', '現在、予約可能なワクチンがありません。');
          return;
        }
        if (errEl) errEl.classList.remove('show');
        renderNames();
      } catch (e) {
        console.error('[loadVaccineMaster]', e);
        if (loadingEl) loadingEl.style.display = 'none';
        showInlineError(null, 'vaxLoadError', 'ワクチン一覧を取得できませんでした。お手数ですが、時間をおいて再度お試しください。');
      }
    }

    function uniqueNames(rows) {
      var seen = {}, out = [];
      rows.forEach(function (r) { if (!seen[r.name]) { seen[r.name] = 1; out.push(r.name); } });
      return out;
    }

    function renderNames() {
      var box = $("nameList");
      box.innerHTML = "";
      uniqueNames(ROWS).forEach(function (name) {
        var label = document.createElement("label");
        label.className = "name";
        var input = document.createElement("input");
        input.type = "radio"; input.name = "vname"; input.value = name;
        var span = document.createElement("span");
        span.textContent = name;
        label.appendChild(input); label.appendChild(span);
        box.appendChild(label);
        input.addEventListener("change", function () {
          document.querySelectorAll("#nameList .name").forEach(function (l) { l.classList.remove("sel"); });
          label.classList.add("sel");
          clearInlineError(null, 'vaxNameError');
          selectName(name);
        });
      });

      // ▼ 一覧にないワクチン用の「その他」
      var olabel = document.createElement("label");
      olabel.className = "name";
      var oinput = document.createElement("input");
      oinput.type = "radio"; oinput.name = "vname"; oinput.value = "__other__";
      var ospan = document.createElement("span");
      ospan.textContent = "その他（上記にないワクチン）";
      olabel.appendChild(oinput); olabel.appendChild(ospan);
      box.appendChild(olabel);
      oinput.addEventListener("change", function () {
        document.querySelectorAll("#nameList .name").forEach(function (l) { l.classList.remove("sel"); });
        olabel.classList.add("sel");
        clearInlineError(null, 'vaxNameError');
        selectOther();
      });
    }

    function renderOptions(rows) {
      var box = $("optionList");
      box.innerHTML = "";

      rows.forEach(function (row) {
        var label = document.createElement("label");
        label.className = "opt";
        var input = document.createElement("input");
        input.type = "radio"; input.name = "vopt"; input.value = row.id;
        var body = document.createElement("span");
        body.className = "opt-body";
        var kubunClass = row.kubun === '定期' ? 'teiki' : (row.kubun === '任意' ? 'nini' : '');
        var line1 = (row.kubun ? '<span class="opt-kubun ' + kubunClass + '">' + esc(row.kubun) + '接種</span>' : '') +
          '<span class="opt-prod">' + esc(row.product) + '</span>';
        var sub = (row.target ? '<span class="opt-sub">対象：' + esc(row.target) + '</span>' : '') +
          (row.doses != null && row.doses > 0 ? '<span class="opt-sub">使用回数：' + row.doses + '回</span>' : '') +
          (row.price ? '<span class="opt-price">' + esc(row.price) + '</span>' : '');
        var noteHtml = row.note ? '<span class="opt-note">' + esc(row.note) + '</span>' : '';
        body.innerHTML = line1 + sub + noteHtml;
        label.appendChild(input); label.appendChild(body);
        box.appendChild(label);
        input.addEventListener("change", function () {
          document.querySelectorAll("#optionList .opt").forEach(function (l) { l.classList.remove("sel"); });
          label.classList.add("sel");
          clearInlineError(null, 'vaxOptionError');
          selectRow(row);
        });
