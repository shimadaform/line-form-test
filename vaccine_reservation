<!DOCTYPE html>
<html lang="ja">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#06c755">
  <title>ワクチン接種予約フォーム</title>
  <script charset="utf-8" src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Hiragino Sans", "Yu Gothic", sans-serif;
      max-width: 600px;
      margin: 0 auto;
      padding: 16px;
      background: #f5f5f5;
      color: #333;
      line-height: 1.5;
    }

    h1 {
      font-size: 1.3rem;
      margin: 8px 0 16px;
      padding-bottom: 8px;
      border-bottom: 2px solid #06c755;
    }

    h2 {
      font-size: 1rem;
      margin: 20px 0 10px;
      color: #06c755;
      padding-left: 8px;
      border-left: 4px solid #06c755;
    }

    .badge {
      display: inline-block;
      background: #06c755;
      color: #fff;
      padding: 2px 10px;
      border-radius: 12px;
      font-size: 0.8rem;
      margin-left: 8px;
      vertical-align: middle;
    }

    .badge-required {
      background: none;
      color: #e74c3c;
      font-weight: bold;
      padding: 0;
      margin-right: 6px;
    }

    .badge-optional {
      background: none;
      color: #888;
      font-weight: bold;
      padding: 0;
      margin-right: 6px;
    }

    .test-banner {
      background: #ff9800;
      color: #fff;
      text-align: center;
      padding: 8px;
      font-weight: bold;
      border-radius: 6px;
      margin-bottom: 12px;
    }

    /* ▼ 進捗ステップ */
    .progress {
      display: flex;
      align-items: flex-start;
      margin-bottom: 16px;
      padding: 4px 2px 0;
    }

    .progress .step {
      flex: 0 0 auto;
      text-align: center;
      min-width: 50px;
    }

    .progress .step-circle {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: #ddd;
      color: #888;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.85rem;
      font-weight: bold;
      margin: 0 auto;
      transition: background 0.2s ease, color 0.2s ease;
    }

    .progress .step-label {
      font-size: 0.7rem;
      color: #888;
      margin-top: 4px;
      white-space: nowrap;
      transition: color 0.2s ease, font-weight 0.2s ease;
    }

    .progress .step.active .step-circle {
      background: #06c755;
      color: #fff;
      box-shadow: 0 0 0 3px rgba(6, 199, 85, 0.2);
    }

    .progress .step.active .step-label {
      color: #06c755;
      font-weight: bold;
    }

    .progress .step.completed .step-circle {
      background: #06c755;
      color: #fff;
    }

    .progress .step.completed .step-label {
      color: #555;
    }

    .progress .step-line {
      flex: 1;
      height: 2px;
      background: #ddd;
      margin: 14px 4px 0;
      transition: background 0.2s ease;
    }

    .progress .step-line.completed {
      background: #06c755;
    }

    .field {
      background: #fff;
      padding: 12px;
      margin-bottom: 10px;
      border-radius: 8px;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    }

    .label {
      display: block;
      font-weight: bold;
      margin-bottom: 6px;
      font-size: 0.95rem;
    }

    .required {
      color: #e74c3c;
      font-size: 0.75rem;
      margin-left: 6px;
    }

    .optional {
      color: #888;
      font-size: 0.75rem;
      margin-left: 6px;
    }

    .help {
      font-size: 0.8rem;
      color: #888;
      margin-top: 4px;
    }

    input[type="text"],
    input[type="tel"],
    input[type="date"],
    select,
    textarea {
      width: 100%;
      padding: 10px;
      font-size: 1rem;
      border: 1px solid #ccc;
      border-radius: 6px;
      background: #fff;
    }

    input:focus,
    select:focus,
    textarea:focus {
      outline: none;
      border-color: #06c755;
    }

    input:user-invalid,
    select:user-invalid {
      border-color: #e74c3c;
    }

    form.form-submitted input:invalid,
    form.form-submitted select:invalid {
      border-color: #e74c3c;
    }

    input.has-error,
    select.has-error {
      border-color: #e74c3c !important;
    }

    /* ▼ 生年月日(年/月/日)の横並び */
    .birthday-group {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .birthday-group select {
      flex: 1 1 0;
      min-width: 0;
      padding: 10px 6px;
    }

    .birthday-group select.year {
      flex: 1.5 1 0;
    }

    .birthday-unit {
      flex: 0 0 auto;
      font-size: 0.9rem;
      color: #555;
    }

    input:disabled {
      background: #f0f0f0;
      color: #999;
      cursor: not-allowed;
    }

    .checkboxes label {
      display: block;
      padding: 6px 0;
      font-size: 0.95rem;
    }

    .checkboxes input {
      margin-right: 8px;
    }

    /* ▼ 2択ラジオの横並び(性別) */
    .checkboxes.inline {
      display: flex;
      gap: 24px;
    }

    .checkboxes.inline label {
      display: flex;
      align-items: center;
      padding: 10px 4px;
    }

    /* ===== ワクチン選択UI ===== */
    label.opt,
    label.name {
      display: block;
      border: 1px solid #ccc;
      border-radius: 6px;
      padding: 10px 12px;
      margin-bottom: 8px;
      cursor: pointer;
    }

    label.opt.sel,
    label.name.sel {
      border-color: #06c755;
      background: #e8f5e9;
    }

    .opt input,
    .name input {
      margin-right: 8px;
      accent-color: #06c755;
      vertical-align: top;
    }

    .opt-body {
      display: inline-block;
      width: calc(100% - 28px);
      vertical-align: top;
    }

    .opt-kubun {
      display: inline-block;
      font-size: 0.95rem;
      font-weight: bold;
      color: #fff;
      background: #607d8b;
      border-radius: 6px;
      padding: 4px 14px;
      margin-bottom: 6px;
      letter-spacing: .03em;
    }

    .opt-kubun.teiki {
      background: #1565c0;
    }

    .opt-kubun.nini {
      background: #00897b;
    }

    .opt-prod {
      display: block;
      font-weight: bold;
      font-size: 1.02rem;
    }

    .opt-sub {
      display: block;
      font-size: 0.85rem;
      color: #555;
    }

    .opt-price {
      display: block;
      font-size: 0.9rem;
      color: #d84315;
      font-weight: bold;
      margin-top: 2px;
    }

    .opt-note {
      display: block;
      font-size: 0.82rem;
      color: #555;
      margin-top: 6px;
      padding-top: 6px;
      border-top: 1px dashed #e0e0e0;
    }

    .common-note {
      font-size: 0.82rem;
      color: #777;
      margin-bottom: 10px;
    }

    .qblock {
      margin-top: 12px;
      padding-top: 12px;
      border-top: 1px dashed #ddd;
    }

    .qblock p {
      margin: 0 0 6px;
      font-weight: bold;
      font-size: 0.92rem;
    }

    .qrow label {
      display: inline-block;
      margin-right: 18px;
      cursor: pointer;
    }

    .qrow input {
      margin-right: 5px;
      accent-color: #06c755;
      width: auto;
    }

    .sub {
      margin-top: 8px;
    }

    .sub label {
      display: block;
      font-size: 0.9rem;
    }

    .sub select,
    .sub input[type="date"] {
      width: 100%;
      margin-top: 4px;
    }

    .warn {
      color: #c62828;
      font-size: 0.85rem;
      margin-top: 6px;
    }

    .vax-loading {
      color: #888;
      font-size: 0.9rem;
      padding: 8px 0;
    }

    .spinner-sm {
      display: inline-block;
      width: 16px;
      height: 16px;
      border: 2px solid #ddd;
      border-top-color: #06c755;
      border-radius: 50%;
      animation: spin .8s linear infinite;
      vertical-align: -3px;
      margin-right: 6px;
    }

    button.submit {
      width: 100%;
      padding: 14px;
      font-size: 1.05rem;
      background: #06c755;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-weight: bold;
      margin-top: 16px;
      cursor: pointer;
    }

    button.submit:disabled {
      background: #aaa;
      cursor: not-allowed;
    }

    .btn-spinner {
      display: inline-block;
      width: 14px;
      height: 14px;
      border: 2px solid rgba(255, 255, 255, 0.3);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin-right: 8px;
      vertical-align: -2px;
    }

    .close-line-btn {
      margin-top: 14px;
      max-width: 260px;
      display: block;
      margin-left: auto;
      margin-right: auto;
    }

    #result {
      margin-top: 16px;
      padding: 12px;
      border-radius: 6px;
      display: none;
    }

    #result.ok {
      background: #e8f5e9;
      color: #2e7d32;
      display: block;
    }

    #result.ng {
      background: #ffebee;
      color: #c62828;
      display: block;
    }

    .loading {
      text-align: center;
      padding: 60px 20px;
      color: #888;
    }

    .spinner {
      display: inline-block;
      width: 32px;
      height: 32px;
      border: 3px solid #ddd;
      border-top-color: #06c755;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin-bottom: 12px;
    }

    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }

    .alert-box {
      background: #fff3e0;
      border: 2px solid #ff9800;
      border-radius: 8px;
      padding: 14px;
      margin-bottom: 16px;
      font-size: 0.95rem;
      line-height: 1.7;
    }

    .alert-box .icon {
      font-size: 1.2rem;
      margin-right: 4px;
    }

    .alert-box .phone {
      display: block;
      margin-top: 8px;
      font-size: 1.1rem;
      font-weight: bold;
      color: #d84315;
      text-decoration: none;
    }

    .terms {
      background: #fff;
      padding: 14px;
      border-radius: 8px;
      margin-bottom: 16px;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
      font-size: 0.88rem;
      line-height: 1.7;
    }

    .terms h3 {
      font-size: 1rem;
      margin: 0 0 10px;
      color: #06c755;
    }

    .terms ul {
      padding-left: 1.2em;
      margin: 0;
    }

    .terms li {
      margin-bottom: 6px;
    }

    .terms strong {
      color: #049f43;
    }

    .agree-box {
      background: #fff;
      padding: 14px;
      border-radius: 8px;
      margin-bottom: 16px;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    }

    .agree-box label {
      display: flex;
      align-items: center;
      font-size: 0.95rem;
      cursor: pointer;
    }

    .agree-box input {
      margin-right: 10px;
      transform: scale(1.2);
    }

    #selectScreen .intro {
      background: #fff;
      padding: 14px;
      border-radius: 8px;
      margin-bottom: 16px;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .select-btn {
      display: block;
      width: 100%;
      background: #fff;
      border: 2px solid #06c755;
      border-radius: 12px;
      padding: 18px 16px;
      margin-bottom: 12px;
      text-align: left;
      cursor: pointer;
      transition: background 0.15s;
      font-family: inherit;
    }

    .select-btn:hover,
    .select-btn:active {
      background: #e8f5e9;
    }

    .select-btn .title {
      font-size: 1.05rem;
      font-weight: bold;
      color: #06c755;
      margin-bottom: 4px;
    }

    .select-btn .desc {
      font-size: 0.85rem;
      color: #666;
      line-height: 1.5;
    }

    .select-btn .arrow {
      float: right;
      color: #06c755;
      font-size: 1.3rem;
      font-weight: bold;
    }

    .back-btn {
      background: none;
      border: none;
      color: #06c755;
      font-size: 0.95rem;
      padding: 4px 0;
      margin-bottom: 8px;
      cursor: pointer;
      font-family: inherit;
    }

    .back-btn:hover {
      text-decoration: underline;
    }

    .referral-box {
      background: #fff;
      padding: 20px;
      border-radius: 8px;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
      text-align: center;
      line-height: 1.7;
    }

    .referral-box .phone-link {
      display: block;
      margin-top: 16px;
      padding: 14px;
      background: #06c755;
      color: #fff;
      font-size: 1.2rem;
      font-weight: bold;
      border-radius: 8px;
      text-decoration: none;
    }

    /* ▼「その他」選択時のみ表示する入力欄 */
    .other-detail {
      display: none;
    }

    .other-detail.show {
      display: block;
    }

    .inline-error {
      color: #c62828;
      font-size: 0.8rem;
      margin-top: 4px;
      display: none;
    }

    .inline-error.show {
      display: block;
    }

    .section-notice {
      background: #fff8e1;
      border-left: 4px solid #ffa726;
      padding: 10px 12px;
      margin: 0 0 12px;
      border-radius: 4px;
      font-size: 0.9rem;
      line-height: 1.7;
      color: #5d4037;
    }

    .section-notice div+div {
      margin-top: 2px;
    }
  </style>
</head>

<body>

  <div id="testBanner" class="test-banner" style="display:none;">🧪 テストモード(LINEログインなし)</div>

  <nav id="progressBar" class="progress" style="display:none;" aria-label="入力の進捗">
    <div class="step" data-step="1">
      <div class="step-circle">1</div>
      <div class="step-label">はじめに</div>
    </div>
    <div class="step-line"></div>
    <div class="step" data-step="2">
      <div class="step-circle">2</div>
      <div class="step-label">選択</div>
    </div>
    <div class="step-line"></div>
    <div class="step" data-step="3">
      <div class="step-circle">3</div>
      <div class="step-label">入力</div>
    </div>
    <div class="step-line"></div>
    <div class="step" data-step="4">
      <div class="step-circle">4</div>
      <div class="step-label">完了</div>
    </div>
  </nav>

  <div id="loading" class="loading">
    <div class="spinner"></div>
    <p>読み込み中...</p>
  </div>

  <!-- ▼ 申込中画面 -->
  <div id="pendingScreen" style="display:none;">
    <h1>ワクチン接種予約フォーム</h1>
    <div class="alert-box" role="alert">
      <span class="icon">📩</span><strong>現在、お申し込みを受付中です。</strong><br>
      <span data-message="CONTACT_NOTICE"></span><br>
      今しばらくお待ちください。
    </div>
    <div class="terms">
      <p style="margin:0;" data-message="URGENT_PHONE_NOTICE"></p>
    </div>
  </div>

  <!-- ▼ はじめに -->
  <div id="introScreen" style="display:none;">
    <h1>ワクチン接種予約フォーム</h1>

    <div class="alert-box" role="alert">
      <span class="icon">⚠️</span><strong>発熱や体調不良があるときは、当日接種できない場合があります。重いアレルギーの既往がある方は、事前にお電話でご相談ください。</strong>
      <a href="#" class="phone" data-clinic-phone-link>📞 <span data-clinic-phone-display></span></a>
    </div>

    <div class="terms">
      <h3>ご利用にあたって</h3>
      <ul>
        <li>
          <strong>予約申込について:</strong>
          本フォームは「予約申込」であり、この時点では予約は確定していません。当院からのご連絡をもって予約確定となります。
        </li>
        <li>
          <strong>ご連絡について:</strong>
          <span data-message="CONTACT_NOTICE"></span>
        </li>
        <li>
          <strong>予約希望日について:</strong>
          ワクチンの在庫状況や接種枠により、ご希望の日に添えない場合があります。また、時間や医師のご指定はできません。
        </li>
        <li>
          <strong>キャンセル・変更について:</strong>
          ワクチンの準備・在庫管理の都合がありますので、キャンセル・変更をご希望の場合は、できるだけ早めにお電話でご連絡ください。
        </li>
        <li>
          <strong>料金について:</strong>
          表示している料金は、主に<span data-city></span>にお住まいの方向けの内容です。他の市町村にお住まいの方は、料金が異なる場合があります。
        </li>
        <li>
          <strong>公費接種について:</strong>
          定期接種・公費助成の対象となるかは、年齢・お住まい・接種歴・接種券などにより確認します。対象とならない場合は、自費での接種となることがあります。
        </li>
        <li>
          <strong>接種可否・体調不良時について:</strong>
          予約が確定していても、当日の体温・体調・接種歴・予診の内容や医師の判断により、接種を見合わせる場合があります。発熱や急な体調不良があるときは、来院前にお電話でご相談ください。
        </li>
        <li>
          <strong>未成年者について:</strong>
          未成年の方は、保護者の同意または同伴が必要となる場合があります。年齢や接種するワクチンの種類により確認させていただきます。
        </li>
        <li>
          <strong>来院時のお持ち物について:</strong>
          <ul class="items">
            <li>
              <span class="badge badge-required">必須</span>
              マイナ保険証（マイナンバーカード）または資格確認書などの本人確認書類
            </li>
            <li>
              <span class="badge badge-optional">任意</span><span class="note">（お持ちの方のみ）</span>
              <ul>
                <li>接種券・助成券・案内はがき</li>
                <li>母子手帳・接種済証</li>
                <li>お薬手帳</li>
              </ul>
            </li>
          </ul>
        </li>
      </ul>
    </div>

    <div class="agree-box">
      <label>
        <input type="checkbox" id="agreeCheck">
        上記内容に同意します
      </label>
    </div>

    <button type="button" class="submit" id="proceedBtn" disabled>次へ進む</button>
  </div>

  <!-- ▼ 選択 -->
  <div id="selectScreen" style="display:none;">
    <button type="button" class="back-btn" data-back="intro">← はじめに戻る</button>
    <h1>ご希望の選択</h1>

    <div class="intro">
      該当するものを選択してください。
    </div>

    <button type="button" class="select-btn" data-type="single">
      <span class="arrow">›</span>
      <div class="title">接種したいワクチンが1種類のみの方</div>
      <div class="desc">1種類のワクチンの接種を希望される場合</div>
    </button>

    <button type="button" class="select-btn" data-type="multi">
      <span class="arrow">›</span>
      <div class="title">複数のワクチンを接種したい方</div>
      <div class="desc">2種類以上の接種をご希望の場合（接種間隔の確認が必要なため、お電話でのご予約となります）</div>
    </button>
  </div>

  <!-- ▼ 入力フォーム -->
  <div id="formScreen" style="display:none;">
    <button type="button" class="back-btn" data-back="select">← 選択に戻る</button>
    <h1>ワクチン接種予約</h1>

    <form id="form" onsubmit="return false;" novalidate>

      <h2>① ご本人について</h2>

      <div class="field">
        <label class="label" for="nameInput">氏名<span class="required">必須</span></label>
        <input type="text" id="nameInput" name="name" required autocomplete="name" maxlength="100"
          placeholder="例:嶋田 太郎">
      </div>

      <div class="field">
        <label class="label" for="kanaInput">フリガナ<span class="required">必須</span></label>
        <input type="text" name="kana" id="kanaInput" required autocomplete="off" maxlength="100"
          placeholder="例:シマダ タロウ">
        <div class="inline-error" id="kanaError" role="alert">カタカナで入力してください</div>
      </div>

      <div class="field">
        <div class="label" id="birthdayLabel">生年月日<span class="required">必須</span></div>
        <div class="birthday-group">
          <select class="year" name="birthdayYear" id="birthdayYear" required autocomplete="bday-year"
            aria-label="生年(西暦)">
            <option value="">----</option>
          </select>
          <span class="birthday-unit">年</span>
          <select name="birthdayMonth" id="birthdayMonth" required autocomplete="bday-month" aria-label="月">
            <option value="">--</option>
          </select>
          <span class="birthday-unit">月</span>
