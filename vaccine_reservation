    // =============================================================
    const CLINIC_INFO = {
      phoneDisplay: '', // 画面表示用(ハイフンあり可、例: 03-1234-5678)
      phoneTel: '',    // tel:リンク用(数字のみ、例: 0312345678)
      hours: '平日 9:00〜17:00（祝日の場合は除く）',
