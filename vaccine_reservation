    function isValidPhone(phone) {
      const digits = phone.replace(/[\s\-\(\)]/g, '');
      return /^0\d{9,10}$/.test(digits);
    }

    function showInlineError(input, errorId, msg) {
      if (input) input.classList.add('has-error');
      const errEl = $(errorId);
      if (errEl) {
        if (msg !== undefined) errEl.textContent = msg;
        errEl.classList.add('show');
      }
    }
    function clearInlineError(input, errorId) {
      if (input) input.classList.remove('has-error');
      const errEl = $(errorId);
      if (errEl) errEl.classList.remove('show');
    }

    function validatePreferredDate(input) {
      const errorId = input.name + 'Error';
      const v = input.value;
      if (!v) { clearInlineError(input, errorId); return; }
      if (!/^\d{4}-\d{2}-\d{2}$/.test(v)) { showInlineError(input, errorId, '年は4桁で入力してください(例:2026)'); return; }
      const min = input.getAttribute('min');
      const max = input.getAttribute('max');
      if (min && v < min) { showInlineError(input, errorId, `${toSlashDate(min)}以降の日付を入力してください`); return; }
      if (max && v > max) { showInlineError(input, errorId, `${toSlashDate(max)}以前の日付を入力してください`); return; }
      const preferredFields = [
        { name: 'preferredDate1', label: '第1希望日' },
        { name: 'preferredDate2', label: '第2希望日' },
        { name: 'preferredDate3', label: '第3希望日' },
      ];
      for (const p of preferredFields) {
        const el = document.querySelector(`input[name="${p.name}"]`);
        if (!el || el === input) continue;
        if (el.value === v) { showInlineError(input, errorId, `${p.label}と同じ日付は選択できません`); return; }
      }
      clearInlineError(input, errorId);
    }

    function revalidateAllPreferredDates() {
      ['preferredDate1', 'preferredDate2', 'preferredDate3'].forEach(name => {
        const el = document.querySelector(`input[name="${name}"]`);
        if (el) validatePreferredDate(el);
      });
    }

    // ▼ 生年月日(年/月/日セレクト)関連 ----------------------------
    function populateBirthdaySelects() {
      const yearSel = $('birthdayYear');
      const monthSel = $('birthdayMonth');
      const currentYear = new Date().getFullYear();
      for (let y = currentYear; y >= 1899; y--) {
        const opt = document.createElement('option');
        opt.value = String(y); opt.textContent = String(y);
        yearSel.appendChild(opt);
      }
      for (let m = 1; m <= 12; m++) {
        const opt = document.createElement('option');
        opt.value = String(m); opt.textContent = String(m);
        monthSel.appendChild(opt);
      }
      updateBirthdayDayOptions();
    }

    function daysInMonth(year, month) {
      if (!month) return 31;
      const y = year || 2000;
      return new Date(y, month, 0).getDate();
    }

    function updateBirthdayDayOptions() {
      const yearSel = $('birthdayYear');
      const monthSel = $('birthdayMonth');
      const daySel = $('birthdayDay');
      const y = parseInt(yearSel.value, 10) || null;
      const mo = parseInt(monthSel.value, 10) || null;
      const maxDay = daysInMonth(y, mo);
      const prev = daySel.value;
      daySel.innerHTML = '<option value="">--</option>';
      for (let d = 1; d <= maxDay; d++) {
        const opt = document.createElement('option');
        opt.value = String(d); opt.textContent = String(d);
        daySel.appendChild(opt);
      }
      if (prev && parseInt(prev, 10) <= maxDay) daySel.value = prev;
    }

    function getBirthdayFromSelects() {
      const y = $('birthdayYear').value;
      const mo = $('birthdayMonth').value;
      const d = $('birthdayDay').value;
      if (!y || !mo || !d) return null;
      const yi = parseInt(y, 10), moi = parseInt(mo, 10), di = parseInt(d, 10);
      const date = new Date(yi, moi - 1, di);
      if (date.getFullYear() !== yi || date.getMonth() !== moi - 1 || date.getDate() !== di) return null;
      return `${yi}-${String(moi).padStart(2, '0')}-${String(di).padStart(2, '0')}`;
    }

    function setBirthdayError(msg) {
      ['birthdayYear', 'birthdayMonth', 'birthdayDay'].forEach(id => { $(id).classList.add('has-error'); });
      const errEl = $('birthdayError');
      if (errEl) { errEl.textContent = msg; errEl.classList.add('show'); }
    }

    function clearBirthdayError() {
      ['birthdayYear', 'birthdayMonth', 'birthdayDay'].forEach(id => {
        const el = $(id); if (el) el.classList.remove('has-error');
      });
      const errEl = $('birthdayError');
      if (errEl) errEl.classList.remove('show');
    }

    // ▼ ワクチン選択のバリデーション
    function validateVaccine() {
      const b = calcDateBoundaries();
      if (!currentVaxName) {
        showInlineError(null, 'vaxNameError', '接種するワクチンを選択してください');
        $('nameList').scrollIntoView({ block: 'center' });
        return null;
      }
      if (!selectedRow) {
        showInlineError(null, 'vaxOptionError', '内容を選択してください');
        $('optionList').scrollIntoView({ block: 'center' });
        return null;
      }
      if (selectedRow.consult) {
        return { vaccineName: currentVaxName, consult: true };
      }
      if (selectedRow.ticket) {
        return { vaccineName: currentVaxName, ticket: true };
      }
      if (selectedRow.other) {
        const fundSel = document.querySelector('input[name="otherFund"]:checked');
        if (!fundSel) {
          showInlineError(null, 'vaxOptionError', '公費・自費のいずれかを選択してください');
          $('optionList').scrollIntoView({ block: 'center' });
          return null;
        }
        const otherNameInput = $('otherVaxNameInput');
        const otherNameVal = otherNameInput ? otherNameInput.value.trim() : '';
        if (!otherNameVal) {
          showInlineError(otherNameInput, 'otherVaxNameError', 'ワクチン名を入力してください');
          if (otherNameInput) otherNameInput.focus();
          return null;
        }
        return { vaccineName: otherNameVal, other: true, fundType: fundSel.value };
      }
      const row = selectedRow;
      const data = { vaccineName: currentVaxName, consult: false, menuId: row.id, kubun: row.kubun, product: row.product };

      if (row.doses != null && row.doses >= 2) {
        const ds = $('doseSelect');
        if (!ds.value) { showInlineError(null, 'vaxDoseError', '今回が何回目かを選択してください'); ds.focus(); return null; }
        data.doseNumber = (ds.value === '1') ? 'はじめて' : (ds.value + '回目');
        if (ds.value !== '1') {
          const dd = $('doseDate');
          if (!dd.value) { showInlineError(dd, 'doseDateError', '前回の接種日を入力してください'); dd.focus(); return null; }
          if (dd.value > b.TODAY) { showInlineError(dd, 'doseDateError', '前回の接種日は今日以前を入力してください'); dd.focus(); return null; }
          data.lastDoseDate = dd.value;
        }
      }

      const h = (row.history || '').trim();
      if (h && h !== 'なし' && h.toUpperCase() !== 'FALSE' && h !== '0') {
        const histSel = document.querySelector('input[name="hist"]:checked');
        if (!histSel) { showInlineError(null, 'histAnsError', '接種歴について選択してください'); return null; }
        data.historyMode = h;
        data.historyAnswer = histSel.value;
        if (histSel.value === 'yes') {
          if (h === '過去全て') {
            const hp = $('histPeriod');
            if (!hp.value) { showInlineError(null, 'histPeriodError', '前回の接種時期を選択してください'); hp.focus(); return null; }
            data.historyPeriod = hp.value;
          } else {
            const hd = $('histDate');
            if (!hd.value) { showInlineError(hd, 'histDateError', '接種日を入力してください'); hd.focus(); return null; }
            if (hd.value > b.TODAY) { showInlineError(hd, 'histDateError', '接種日は今日以前を入力してください'); hd.focus(); return null; }
            data.historyDate = hd.value;
          }
        }
      }

      if (row.liveInj) {
        const liSel = document.querySelector('input[name="liveInj"]:checked');
        if (!liSel) { showInlineError(null, 'liveInjAnsError', '別のワクチンの接種について選択してください'); return null; }
        data.otherVaxAnswer = liSel.value;
        if (liSel.value === 'yes') {
          const ln = $('liveInjName');
          const ld = $('liveInjDate');
          if (!ln.value) { showInlineError(null, 'liveInjNameError', '接種したワクチンを選択してください'); ln.focus(); return null; }
          if (!ld.value) { showInlineError(ld, 'liveInjDateError', '接種日を入力してください'); ld.focus(); return null; }
          if (ld.value > b.TODAY) { showInlineError(ld, 'liveInjDateError', '接種日は今日以前を入力してください'); ld.focus(); return null; }
          data.otherVaxName = ln.value;
          data.otherVaxDate = ld.value;
        }
      }
      return data;
    }

    function validateForm(form) {
      // 1. ワクチン選択
      const vax = validateVaccine();
      if (!vax) return null;

      // 2. 必須項目（HTML）
      if (!form.checkValidity()) {
        form.reportValidity();
        const firstInvalid = form.querySelector(':invalid');
        if (firstInvalid) firstInvalid.focus();
        return null;
      }

      // 3. フリガナ
      const kanaInput = $('kanaInput');
      if (!KANA_REGEX.test(kanaInput.value.trim())) {
        showInlineError(kanaInput, 'kanaError', 'カタカナで入力してください');
        kanaInput.focus();
        return null;
      }

      // 4. 電話番号
      const phoneInput = $('phoneInput');
      if (!isValidPhone(phoneInput.value)) {
        showInlineError(phoneInput, 'phoneError', '電話番号の形式が正しくありません。0から始まる10〜11桁の番号を入力してください(ハイフンあり/なし可)。');
        phoneInput.focus();
        return null;
      }

      // 5. 生年月日
      const birthday = getBirthdayFromSelects();
      if (!birthday) {
        setBirthdayError('生年月日を正しく選択してください');
        $('birthdayYear').focus();
        return null;
      }

      // 6. 性別
      const genderSelected = form.querySelector('input[name="gender"]:checked');
      if (!genderSelected) {
        showInlineError(null, 'genderError', '性別を選択してください');
        const g = form.querySelector('input[name="gender"]'); if (g) g.focus();
        return null;
      }

      // 7. 希望日の形式・範囲・重複
      const preferredDate1 = form.querySelector('input[name="preferredDate1"]').value;
      const preferredDate2 = form.querySelector('input[name="preferredDate2"]').value;
      const preferredDate3 = form.querySelector('input[name="preferredDate3"]').value;

      const dateFormatRe = /^\d{4}-\d{2}-\d{2}$/;
      const dateChecks = [
        { label: '第1希望日', value: preferredDate1, name: 'preferredDate1' },
        { label: '第2希望日', value: preferredDate2, name: 'preferredDate2' },
        { label: '第3希望日', value: preferredDate3, name: 'preferredDate3' },
      ];
      for (const { label, value, name } of dateChecks) {
        if (value && !dateFormatRe.test(value)) {
          const inp = form.querySelector(`input[name="${name}"]`);
          showInlineError(inp, name + 'Error', `${label}の年は4桁で入力してください(例:2026)`);
          if (inp) inp.focus();
          return null;
        }
      }

      const b = calcDateBoundaries();
      applyDateBoundariesToDOM(b);

      if (birthday < b.BIRTHDAY_MIN || birthday > b.TODAY) {
        setBirthdayError(`生年月日は ${toJpDate(b.BIRTHDAY_MIN)} 〜 ${toJpDate(b.TODAY)} の範囲で入力してください`);
        $('birthdayYear').focus();
        return null;
      }
      if (preferredDate1 < b.PREFERRED_MIN || preferredDate1 > b.PREFERRED_MAX) {
        const inp = form.querySelector('input[name="preferredDate1"]');
        showInlineError(inp, 'preferredDate1Error', `第1希望日は ${toJpDate(b.PREFERRED_MIN)} 〜 ${toJpDate(b.PREFERRED_MAX)} の範囲で入力してください`);
        if (inp) inp.focus();
        return null;
      }
      if (preferredDate2 && (preferredDate2 < b.PREFERRED_MIN || preferredDate2 > b.PREFERRED_MAX)) {
        const inp = form.querySelector('input[name="preferredDate2"]');
        showInlineError(inp, 'preferredDate2Error', `第2希望日は ${toJpDate(b.PREFERRED_MIN)} 〜 ${toJpDate(b.PREFERRED_MAX)} の範囲で入力してください`);
        if (inp) inp.focus();
        return null;
      }
      if (preferredDate3 && (preferredDate3 < b.PREFERRED_MIN || preferredDate3 > b.PREFERRED_MAX)) {
        const inp = form.querySelector('input[name="preferredDate3"]');
        showInlineError(inp, 'preferredDate3Error', `第3希望日は ${toJpDate(b.PREFERRED_MIN)} 〜 ${toJpDate(b.PREFERRED_MAX)} の範囲で入力してください`);
        if (inp) inp.focus();
        return null;
      }

      const preferredVals = [preferredDate1, preferredDate2, preferredDate3].filter(v => v);
      if (preferredVals.length !== new Set(preferredVals).size) {
        revalidateAllPreferredDates();
        const firstErr = form.querySelector('input[name^="preferredDate"].has-error');
        if (firstErr) firstErr.focus();
        return null;
      }

      // 8. 申込者
      const applicantSelected = form.querySelector('input[name="applicant"]:checked');
      if (!applicantSelected) {
        showInlineError(null, 'applicantError', '申込者を選択してください');
        const a = form.querySelector('input[name="applicant"]'); if (a) a.focus();
        return null;
      }

      return { vax, birthday };
    }

    function buildPayload(form, validated) {
      const formData = {};
      new FormData(form).forEach((v, k) => {
        if (k === 'birthdayYear' || k === 'birthdayMonth' || k === 'birthdayDay') return;
        formData[k] = v;
      });
      formData.type = currentType;
      formData.birthday = validated.birthday;
      formData.vaccine = validated.vax;
      formData.submissionId = submissionState.id;
      return formData;
    }

    async function submitToServer(formData) {
      const payload = {
        idToken: TEST_MODE ? null : liff.getIDToken(),
        formData,
        appToken: APP_TOKEN
      };
      if (TEST_MODE) payload.testMode = true;
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 30000);
      try {
        const res = await fetch(GAS_URL, { method: 'POST', body: JSON.stringify(payload), signal: controller.signal });
        return JSON.parse(await res.text());
      } finally {
        clearTimeout(timeoutId);
      }
    }

    function showSubmitSuccess(result, form) {
      result.className = 'ok';
      result.style.display = '';
      let html = '✅ <strong>予約申込を受け付けました。</strong><br>' +
        getMessage('CONTACT_NOTICE') + '<br><br>' + getMessage('URGENT_PHONE_NOTICE');
      const canCloseLiff = !TEST_MODE && typeof liff !== 'undefined' && typeof liff.closeWindow === 'function';
      if (canCloseLiff) html += '<button type="button" class="submit close-line-btn">LINEに戻る</button>';
      result.innerHTML = html;
      if (canCloseLiff) {
        const closeBtn = result.querySelector('.close-line-btn');
        if (closeBtn) closeBtn.addEventListener('click', () => { try { liff.closeWindow(); } catch (e) { console.error('[closeWindow]', e); } });
      }
      form.style.display = 'none';
      const backBtn = document.querySelector('#formScreen .back-btn');
      if (backBtn) backBtn.style.display = 'none';
      updateProgressBar(4);
      history.replaceState({ screen: 'complete' }, '');
    }

    function showAlreadySubmitted(result, form) {
      result.className = 'ok';
      result.style.display = '';
      result.innerHTML = '📩 <strong>現在、お申し込みを受付中です。</strong><br>' +
        getMessage('CONTACT_NOTICE') + '<br><br>' + getMessage('URGENT_PHONE_NOTICE');
      form.style.display = 'none';
      const backBtn = document.querySelector('#formScreen .back-btn');
      if (backBtn) backBtn.style.display = 'none';
      updateProgressBar(4);
      history.replaceState({ screen: 'complete' }, '');
    }

    function showSubmitFailure(result, btn, errorDetail) {
      console.error('[Submit Error]', errorDetail);
      result.className = 'ng';
      result.style.display = '';
      result.innerHTML = '送信に失敗しました。<br>お手数ですが、もう一度お試しいただくか、お電話(' + getPhoneHtml() + ')でご連絡ください。';
      btn.disabled = false;
      btn.textContent = '予約を申し込む';
    }

    function showNetworkFailure(result, btn, err) {
      console.error('[Network Error]', err);
      result.className = 'ng';
      result.style.display = '';
      if (err && err.name === 'AbortError') {
        result.textContent = '通信がタイムアウトしました。電波の良い場所で、もう一度お試しください。';
      } else {
        result.textContent = '通信エラーが発生しました。ネットワークの状態をご確認のうえ、もう一度お試しください。';
      }
      btn.disabled = false;
      btn.textContent = '予約を申し込む';
    }

    async function handleSubmit() {
      if (submissionState.inFlight) return;
      if (submissionState.completed) return;

      const form = $('form');
      const btn = $('submitBtn');
      const result = $('result');

      if (currentType !== 'single') {
        result.className = 'ng';
        result.style.display = '';
        result.textContent = '最初からやり直してください。';
        return;
      }

      form.classList.add('form-submitted');

      const validated = validateForm(form);
      if (!validated) return;

      if (!GAS_URL) {
        result.className = 'ng';
        result.style.display = '';
        result.textContent = '送信先（GAS_URL）が設定されていません。設定後にお試しください。';
        return;
      }

      const formData = buildPayload(form, validated);

      submissionState.inFlight = true;
      btn.disabled = true;
      btn.innerHTML = '<span class="btn-spinner" aria-hidden="true"></span>送信中...';
      result.className = '';
      result.style.display = '';

      try {
        const data = await submitToServer(formData);
        if (data.ok) {
          submissionState.completed = true;
          submissionState.inFlight = false;
          formDirty = false;
          showSubmitSuccess(result, form);
        } else if (data.error === 'already_submitted') {
          submissionState.completed = true;
          submissionState.inFlight = false;
          formDirty = false;
          showAlreadySubmitted(result, form);
        } else {
          submissionState.inFlight = false;
          showSubmitFailure(result, btn, data.error);
        }
      } catch (err) {
        submissionState.inFlight = false;
        showNetworkFailure(result, btn, err);
      }
    }
  </script>

