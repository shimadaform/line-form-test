      // 内容が複数あるときは「分からないのでLINEで相談したい」を追加
      if (rows.length > 1) {
        var clabel = document.createElement("label");
        clabel.className = "opt";
        var cinput = document.createElement("input");
        cinput.type = "radio"; cinput.name = "vopt"; cinput.value = "__consult__";
